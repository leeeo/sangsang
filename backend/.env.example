# 로컬 개발: SQLite (DB 서버 불필요)
DATABASE_URL=sqlite:///./sangbusangjo.db

# GitLab CI / 프로덕션 전환 시 아래로 교체:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/sangbusangjo

# 반드시 안전한 랜덤 값으로 교체하세요!
# 생성: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=여기에_안전한_랜덤_키_입력
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

REDIS_URL=redis://localhost:6379
